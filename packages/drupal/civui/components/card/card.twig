<civ-card
  {% if heading %}heading="{{ heading }}"{% endif %}
  {% if spacing %}spacing="{{ spacing }}"{% endif %}
  {% if color %}color="{{ color }}"{% endif %}
  {% if card_style %}card-style="{{ card_style }}"{% endif %}
  {% if icon_start %}icon-start="{{ icon_start }}"{% endif %}
  {% if icon_end %}icon-end="{{ icon_end }}"{% endif %}
>
  {% block default %}{{ default }}{% endblock %}
  {% block footer %}{{ footer }}{% endblock %}
</civ-card>
