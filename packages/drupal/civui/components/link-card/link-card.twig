<civ-link-card
  {% if href %}href="{{ href }}"{% endif %}
  {% if heading %}heading="{{ heading }}"{% endif %}
  {% if description %}description="{{ description }}"{% endif %}
  {% if variant %}variant="{{ variant }}"{% endif %}
  {% if spacing %}spacing="{{ spacing }}"{% endif %}
  {% if color %}color="{{ color }}"{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if icon_start %}icon-start="{{ icon_start }}"{% endif %}
  {% if icon_end %}icon-end="{{ icon_end }}"{% endif %}
  {% if eyebrow %}eyebrow="{{ eyebrow }}"{% endif %}
></civ-link-card>
