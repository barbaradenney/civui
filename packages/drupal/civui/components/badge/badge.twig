<civ-badge
  {% if label %}label="{{ label }}"{% endif %}
  {% if count %}count="{{ count }}"{% endif %}
  {% if max %}max="{{ max }}"{% endif %}
  {% if dot %}dot{% endif %}
  {% if intent %}intent="{{ intent }}"{% endif %}
  {% if emphasis %}emphasis="{{ emphasis }}"{% endif %}
  {% if with_icon %}with-icon{% endif %}
  {% if spacing %}spacing="{{ spacing }}"{% endif %}
  {% if overlay %}overlay{% endif %}
  {% if icon_start %}icon-start="{{ icon_start }}"{% endif %}
  {% if icon_end %}icon-end="{{ icon_end }}"{% endif %}
></civ-badge>
