{
  "name": "@civui/inputs",
  "version": "0.1.0",
  "description": "CivUI input components — Text input, textarea, select, combobox, date picker, file upload, toggle, yes/no",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./text-input": "./dist/text-input/index.js",
    "./textarea": "./dist/textarea/index.js",
    "./select": "./dist/select/index.js",
    "./combobox": "./dist/combobox/index.js",
    "./date-picker": "./dist/date-picker/index.js",
    "./date-range-picker": "./dist/date-range-picker/index.js",
    "./memorable-date": "./dist/date-input/index.js",
    "./file-upload": "./dist/file-upload/index.js",
    "./toggle": "./dist/toggle/index.js",
    "./yes-no": "./dist/yes-no/index.js",
    "./ssn": "./dist/ssn/index.js",
    "./phone": "./dist/phone/index.js",
    "./email": "./dist/email/index.js",
    "./zip": "./dist/zip/index.js",
    "./ein": "./dist/ein/index.js",
    "./currency": "./dist/currency/index.js",
    "./routing-number": "./dist/routing-number/index.js",
    "./us-state": "./dist/us-state/index.js",
    "./country": "./dist/country/index.js",
    "./va-file-number": "./dist/va-file-number/index.js",
    "./service-branch": "./dist/service-branch/index.js",
    "./discharge-type": "./dist/discharge-type/index.js",
    "./suffix": "./dist/suffix/index.js",
    "./relationship-type": "./dist/relationship-type/index.js",
    "./marital-status": "./dist/marital-status/index.js",
    "./ethnicity": "./dist/ethnicity/index.js",
    "./gender": "./dist/gender/index.js",
    "./language": "./dist/language/index.js",
    "./race": "./dist/race/index.js",
    "./preset-input": "./dist/preset-input/index.js"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@civui/core": "workspace:*",
    "@civui/controls": "workspace:*",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@civui/test-utils": "workspace:*",
    "@civui/tokens": "workspace:*",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
