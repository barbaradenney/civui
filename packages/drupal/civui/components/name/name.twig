<civ-name
  {% if legend %}legend="{{ legend }}"{% endif %}
  {% if name %}name="{{ name }}"{% endif %}
  {% if format %}format="{{ format }}"{% endif %}
  {% if show_middle %}show-middle{% endif %}
  {% if show_suffix %}show-suffix{% endif %}
  {% if required %}required{% endif %}
  {% if disabled %}disabled{% endif %}
></civ-name>
