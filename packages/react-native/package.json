{
  "name": "@civui/react-native",
  "version": "0.1.0",
  "description": "CivUI React Native components — mobile companion to @civui/forms",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./forms": "./dist/forms/index.js",
    "./core": "./dist/core/index.js"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "storybook:web": "storybook dev -p 6007 -c .storybook-web",
    "storybook:web:build": "storybook build -c .storybook-web -o storybook-static"
  },
  "dependencies": {
    "@civui/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "@testing-library/jest-native": "^5.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^12.0.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "jest": "^29.0.0",
    "react": "^18.2.0",
    "react-native": "^0.73.0",
    "react-dom": "^18.2.0",
    "react-native-web": "^0.19.0",
    "react-test-renderer": "^18.2.0",
    "@storybook/react": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/addon-a11y": "^8.4.0",
    "storybook": "^8.4.0",
    "typescript": "^5.3.0"
  }
}
