{
  "name": "@civui/storybook-utils",
  "version": "0.1.0",
  "description": "CivUI Storybook-only utilities (demo-frame, story helpers)",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./demo-frame": "./dist/demo-frame/index.js",
    "./demo-frame.css": "./src/demo-frame/demo-frame.css"
  },
  "files": ["dist", "src/demo-frame/demo-frame.css"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@civui/core": "workspace:*",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@civui/test-utils": "workspace:*",
    "@vitest/coverage-v8": "^2.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
