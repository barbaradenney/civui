{
  "name": "@civui/actions",
  "version": "0.1.0",
  "description": "CivUI action + navigation affordances — Button, ActionButton, FilterChip, Link, LinkCard, SkipLink",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./button": "./dist/button/index.js",
    "./action-button": "./dist/action-button/index.js",
    "./filter-chip": "./dist/filter-chip/index.js",
    "./filter-chip-group": "./dist/filter-chip-group/index.js",
    "./link": "./dist/link/index.js",
    "./link-card": "./dist/link-card/index.js",
    "./skip-link": "./dist/skip-link/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
