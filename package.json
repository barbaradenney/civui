{
  "name": "civui",
  "version": "0.1.0",
  "private": true,
  "description": "CivUI - Civic Design System: Accessibility-first web components for government applications",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "lint:fix": "eslint 'packages/*/src/**/*.ts' --fix",
    "format": "prettier --write 'packages/*/src/**/*.{ts,json}'",
    "typecheck": "turbo typecheck",
    "prestorybook": "pnpm --filter @civui/tokens build",
    "storybook": "storybook dev -p 6006",
    "prestorybook:build": "pnpm --filter @civui/tokens build",
    "storybook:build": "storybook build",
    "generate": "pnpm --filter @civui/codegen generate",
    "generate:dry-run": "pnpm --filter @civui/codegen generate:dry-run",
    "generate:validate": "pnpm --filter @civui/codegen validate",
    "generate:diff": "pnpm --filter @civui/codegen diff",
    "validate": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "8.6.17",
    "@storybook/addon-essentials": "8.6.17",
    "@storybook/web-components": "8.6.17",
    "@storybook/web-components-vite": "8.6.17",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "storybook": "8.6.17",
    "tailwindcss": "^3.4.0",
    "turbo": "^2.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
