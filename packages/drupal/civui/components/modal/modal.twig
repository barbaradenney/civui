<civ-modal
  {% if open %}open{% endif %}
  {% if heading %}heading="{{ heading }}"{% endif %}
  {% if label %}label="{{ label }}"{% endif %}
  {% if no_close_button %}no-close-button{% endif %}
  {% if no_backdrop_close %}no-backdrop-close{% endif %}
  {% if no_escape_close %}no-escape-close{% endif %}
  {% if heading_level %}heading-level="{{ heading_level }}"{% endif %}
>
  {% block default %}{{ default }}{% endblock %}
</civ-modal>
