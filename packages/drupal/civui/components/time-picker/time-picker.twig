<civ-time-picker
  {% if legend %}legend="{{ legend }}"{% endif %}
  {% if name %}name="{{ name }}"{% endif %}
  {% if value %}value="{{ value }}"{% endif %}
  {% if hint %}hint="{{ hint }}"{% endif %}
  {% if error %}error="{{ error }}"{% endif %}
  {% if format %}format="{{ format }}"{% endif %}
  {% if minute_step is not null %}minute-step="{{ minute_step }}"{% endif %}
  {% if hour_label %}hour-label="{{ hour_label }}"{% endif %}
  {% if minute_label %}minute-label="{{ minute_label }}"{% endif %}
  {% if period_label %}period-label="{{ period_label }}"{% endif %}
  {% if required %}required{% endif %}
  {% if disabled %}disabled{% endif %}
></civ-time-picker>
