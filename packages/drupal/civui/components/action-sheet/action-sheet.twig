<civ-action-sheet
  {% if open %}open{% endif %}
  {% if max_height %}max-height="{{ max_height }}"{% endif %}
  {% if label %}label="{{ label }}"{% endif %}
  {% if trap_focus %}trap-focus{% endif %}
  {% if no_click_outside_close %}no-click-outside-close{% endif %}
>
  {% block default %}{{ default }}{% endblock %}
</civ-action-sheet>
