<civ-itemized-total
  {% if heading %}heading="{{ heading }}"{% endif %}
  {% if total_label %}total-label="{{ total_label }}"{% endif %}
  {% if total_amount %}total-amount="{{ total_amount }}"{% endif %}
  {% if currency %}currency="{{ currency }}"{% endif %}
  {% if locale %}locale="{{ locale }}"{% endif %}
  {% if total_intent %}total-intent="{{ total_intent }}"{% endif %}
></civ-itemized-total>
