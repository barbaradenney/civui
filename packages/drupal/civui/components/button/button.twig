<civ-button
  {% if label %}label="{{ label }}"{% endif %}
  {% if variant %}variant="{{ variant }}"{% endif %}
  {% if danger %}danger{% endif %}
  {% if type %}type="{{ type }}"{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if icon_start %}icon-start="{{ icon_start }}"{% endif %}
  {% if icon_end %}icon-end="{{ icon_end }}"{% endif %}
  {% if href %}href="{{ href }}"{% endif %}
>
  {% block default %}{{ default }}{% endblock %}
</civ-button>
