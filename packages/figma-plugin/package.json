{
  "name": "@civui/figma-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CivUI Figma plugin — converts @civui/schema component contracts into variant-aware Figma component sets, with bodies rendered from the real Lit web components.",
  "license": "MIT",
  "scripts": {
    "build": "pnpm build:tokens && pnpm build:plugin",
    "build:plugin": "node esbuild.config.mjs",
    "build:tokens": "tsx scripts/build-tokens-subset.ts",
    "build:variants": "tsx scripts/build-variant-matrix.ts",
    "capture": "tsx scripts/capture-variants.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.plugin.json --noEmit",
    "dev": "node esbuild.config.mjs --watch"
  },
  "dependencies": {
    "@civui/schema": "workspace:*",
    "@civui/tokens": "workspace:*"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.108.0",
    "@playwright/test": "^1.59.1",
    "esbuild": "^0.27.4",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
