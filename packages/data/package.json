{
  "name": "@civui/data",
  "version": "0.1.0",
  "description": "CivUI data-collection components — DataGrid, Pagination, Toolbar, BulkActions, FilterableList",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./data-grid": "./dist/data-grid/index.js",
    "./pagination": "./dist/pagination/index.js",
    "./toolbar": "./dist/toolbar/index.js",
    "./bulk-actions": "./dist/bulk-actions/index.js",
    "./filterable-list": "./dist/filterable-list/index.js",
    "./column-visibility": "./dist/column-visibility/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@civui/actions": "workspace:*",
    "@civui/core": "workspace:*",
    "@civui/overlays": "workspace:*",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@civui/inputs": "workspace:*",
    "@civui/layout": "workspace:*",
    "@civui/test-utils": "workspace:*",
    "@civui/tokens": "workspace:*",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
