<civ-alert
  {% if intent %}intent="{{ intent }}"{% endif %}
  {% if heading %}heading="{{ heading }}"{% endif %}
  {% if label %}label="{{ label }}"{% endif %}
  {% if dismissible %}dismissible{% endif %}
  {% if slim %}slim{% endif %}
  {% if heading_level %}heading-level="{{ heading_level }}"{% endif %}
  {% if emphasis %}emphasis="{{ emphasis }}"{% endif %}
  {% if spacing %}spacing="{{ spacing }}"{% endif %}
  {% if collapsible %}collapsible{% endif %}
  {% if open %}open{% endif %}
  {% if full_width %}full-width{% endif %}
>
  {% block default %}{{ default }}{% endblock %}
</civ-alert>
