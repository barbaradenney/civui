<civ-image
  {% if src %}src="{{ src }}"{% endif %}
  {% if webp_src %}webp-src="{{ webp_src }}"{% endif %}
  {% if avif_src %}avif-src="{{ avif_src }}"{% endif %}
  {% if alt %}alt="{{ alt }}"{% endif %}
  {% if width %}width="{{ width }}"{% endif %}
  {% if height %}height="{{ height }}"{% endif %}
  {% if ratio %}ratio="{{ ratio }}"{% endif %}
  {% if fit %}fit="{{ fit }}"{% endif %}
  {% if loading %}loading="{{ loading }}"{% endif %}
  {% if decoding %}decoding="{{ decoding }}"{% endif %}
  {% if fetch_priority %}fetch-priority="{{ fetch_priority }}"{% endif %}
  {% if crossorigin %}crossorigin="{{ crossorigin }}"{% endif %}
  {% if referrerpolicy %}referrerpolicy="{{ referrerpolicy }}"{% endif %}
  {% if variant %}variant="{{ variant }}"{% endif %}
  {% if rounded %}rounded{% endif %}
  {% if size %}size="{{ size }}"{% endif %}
></civ-image>
