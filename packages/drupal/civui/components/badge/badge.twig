<civ-badge
  {% if label %}label="{{ label }}"{% endif %}
  {% if count %}count="{{ count }}"{% endif %}
  {% if max %}max="{{ max }}"{% endif %}
  {% if dot %}dot{% endif %}
  {% if variant %}variant="{{ variant }}"{% endif %}
  {% if badge_style %}badge-style="{{ badge_style }}"{% endif %}
  {% if with_icon %}with-icon{% endif %}
></civ-badge>
