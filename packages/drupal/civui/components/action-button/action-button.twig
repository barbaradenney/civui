<civ-action-button
  {% if label %}label="{{ label }}"{% endif %}
  {% if emphasis %}emphasis="{{ emphasis }}"{% endif %}
  {% if danger %}danger{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if pressed %}pressed{% endif %}
  {% if type %}type="{{ type }}"{% endif %}
  {% if icon_start %}icon-start="{{ icon_start }}"{% endif %}
  {% if icon_end %}icon-end="{{ icon_end }}"{% endif %}
  {% if href %}href="{{ href }}"{% endif %}
  {% if icon_only %}icon-only{% endif %}
  {% if spacing %}spacing="{{ spacing }}"{% endif %}
  {% if current %}current{% endif %}
  {% if loading %}loading{% endif %}
  {% if loading_label %}loading-label="{{ loading_label }}"{% endif %}
></civ-action-button>
