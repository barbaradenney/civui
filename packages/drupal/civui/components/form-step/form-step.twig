<civ-form-step
  {% if persist %}persist{% endif %}
  {% if sensitive %}sensitive{% endif %}
  {% if show_pause %}show-pause{% endif %}
  {% if continue_label %}continue-label="{{ continue_label }}"{% endif %}
  {% if complete_label %}complete-label="{{ complete_label }}"{% endif %}
  {% if heading_level and heading_level != 2 %}heading-level="{{ heading_level }}"{% endif %}
  {% if progress and progress != 'minimal' %}progress="{{ progress }}"{% endif %}
  {% if header_size and header_size != 'secondary' %}header-size="{{ header_size }}"{% endif %}
  {% if step_title %}step-title="{{ step_title }}"{% endif %}
  {% if nav_disabled %}nav-disabled{% endif %}
  {% if hide_nav %}hide-nav{% endif %}
  {% if validate is defined and not validate %}validate="false"{% endif %}
  {% if pause_label %}pause-label="{{ pause_label }}"{% endif %}
>
  {% block default %}{{ default }}{% endblock %}
</civ-form-step>
