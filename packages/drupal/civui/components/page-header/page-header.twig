<civ-page-header
  {% if spacing %}spacing="{{ spacing }}"{% endif %}
  {% if icon_start %}icon-start="{{ icon_start }}"{% endif %}
  {% if icon_end %}icon-end="{{ icon_end }}"{% endif %}
  {% if rhythm %}rhythm="{{ rhythm }}"{% endif %}
>
  {% block tag %}{{ tag }}{% endblock %}
  {% block eyebrow %}{{ eyebrow }}{% endblock %}
  {% block heading %}{{ heading }}{% endblock %}
  {% block subheading %}{{ subheading }}{% endblock %}
</civ-page-header>
