{
  "name": "@civui/core",
  "version": "0.1.0",
  "description": "CivUI core — Base classes, a11y utilities, and shared helpers",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./base": "./dist/base/index.js",
    "./a11y": "./dist/a11y/index.js",
    "./utils": "./dist/utils/index.js",
    "./date": "./dist/date/index.js",
    "./templates": "./dist/templates/index.js",
    "./form-field": "./dist/form-field/index.js",
    "./icon": "./dist/icon/index.js",
    "./styles": "./src/styles/civ.css",
    "./styles/components": "./src/styles/components.css",
    "./styles/material-symbols": "./src/styles/material-symbols.css"
  },
  "files": ["dist", "src/styles"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "peerDependencies": {
    "material-symbols": "^0.44.0"
  },
  "peerDependenciesMeta": {
    "material-symbols": {
      "optional": true
    }
  },
  "devDependencies": {
    "@civui/tokens": "workspace:*",
    "material-symbols": "^0.44.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
