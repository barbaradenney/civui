<civ-text-input
  {% if label %}label="{{ label }}"{% endif %}
  {% if hint %}hint="{{ hint }}"{% endif %}
  {% if error %}error="{{ error }}"{% endif %}
  {% if name %}name="{{ name }}"{% endif %}
  {% if value %}value="{{ value }}"{% endif %}
  {% if type %}type="{{ type }}"{% endif %}
  {% if placeholder %}placeholder="{{ placeholder }}"{% endif %}
  {% if maxlength %}maxlength="{{ maxlength }}"{% endif %}
  {% if required %}required{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if readonly %}readonly{% endif %}
  {% if autocomplete %}autocomplete="{{ autocomplete }}"{% endif %}
  {% if mask %}mask="{{ mask }}"{% endif %}
  {% if validate %}validate="{{ validate }}"{% endif %}
  {% if width %}width="{{ width }}"{% endif %}
  {% if pattern %}pattern="{{ pattern }}"{% endif %}
  {% if minlength %}minlength="{{ minlength }}"{% endif %}
  {% if hide_char_count %}hide-char-count{% endif %}
  {% if inputmode %}inputmode="{{ inputmode }}"{% endif %}
  {% if mask_pattern %}mask-pattern="{{ mask_pattern }}"{% endif %}
  {% if mask_mode %}mask-mode="{{ mask_mode }}"{% endif %}
  {% if prefix %}prefix="{{ prefix }}"{% endif %}
  {% if suffix %}suffix="{{ suffix }}"{% endif %}
  {% if clearable %}clearable{% endif %}
  {% if leading_icon %}leading-icon="{{ leading_icon }}"{% endif %}
  {% if leading_icon_label %}leading-icon-label="{{ leading_icon_label }}"{% endif %}
  {% if trailing_icon %}trailing-icon="{{ trailing_icon }}"{% endif %}
  {% if trailing_icon_label %}trailing-icon-label="{{ trailing_icon_label }}"{% endif %}
  {% if decimals %}decimals="{{ decimals }}"{% endif %}
  {% if min %}min="{{ min }}"{% endif %}
  {% if max %}max="{{ max }}"{% endif %}
  {% if allow_negative %}allow-negative{% endif %}
  {% if spacing %}spacing="{{ spacing }}"{% endif %}
  {% if reveal_password %}reveal-password{% endif %}
></civ-text-input>
