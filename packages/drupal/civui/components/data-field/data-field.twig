<civ-data-field
  {% if label %}label="{{ label }}"{% endif %}
  {% if value %}value="{{ value }}"{% endif %}
  {% if href %}href="{{ href }}"{% endif %}
  {% if hint %}hint="{{ hint }}"{% endif %}
  {% if edit_href %}edit-href="{{ edit_href }}"{% endif %}
  {% if edit_label %}edit-label="{{ edit_label }}"{% endif %}
  {% if spacing %}spacing="{{ spacing }}"{% endif %}
></civ-data-field>
