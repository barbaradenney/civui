<civ-list-item
  {% if href %}href="{{ href }}"{% endif %}
  {% if current %}current{% endif %}
  {% if heading %}heading="{{ heading }}"{% endif %}
  {% if description %}description="{{ description }}"{% endif %}
  {% if error %}error="{{ error }}"{% endif %}
>
  {% block default %}{{ default }}{% endblock %}
  {% block start %}{{ start }}{% endblock %}
  {% block end %}{{ end }}{% endblock %}
</civ-list-item>
