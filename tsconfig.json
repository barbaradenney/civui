{
  "files": [],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false
  },
  "references": [
    { "path": "./packages/core" },
    { "path": "./packages/inputs" },
    { "path": "./packages/controls" },
    { "path": "./packages/compound" },
    { "path": "./packages/form-patterns" },
    { "path": "./packages/test-utils" },

    { "path": "./packages/cli" },
    { "path": "./packages/content" },
    { "path": "./packages/mcp-server" },
    { "path": "./packages/actions" },
    { "path": "./packages/overlays" },
    { "path": "./packages/layout" },
    { "path": "./packages/feedback" }
  ]
}
