<civ-read-more
  {% if open %}open{% endif %}
  {% if more_label %}more-label="{{ more_label }}"{% endif %}
  {% if less_label %}less-label="{{ less_label }}"{% endif %}
  {% if icon %}icon="{{ icon }}"{% endif %}
  {% if size %}size="{{ size }}"{% endif %}
  {% if inline %}inline{% endif %}
  {% if no_fade_trigger %}no-fade-trigger{% endif %}
>
  {% block teaser %}{{ teaser }}{% endblock %}
  {% block rest %}{{ rest }}{% endblock %}
</civ-read-more>
