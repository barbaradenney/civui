<civ-action-link
  {% if type %}type="{{ type }}"{% endif %}
  {% if number %}number="{{ number }}"{% endif %}
  {% if address %}address="{{ address }}"{% endif %}
  {% if subject %}subject="{{ subject }}"{% endif %}
  {% if href %}href="{{ href }}"{% endif %}
  {% if filename %}filename="{{ filename }}"{% endif %}
  {% if file_size %}file-size="{{ file_size }}"{% endif %}
  {% if label %}label="{{ label }}"{% endif %}
  {% if disabled %}disabled{% endif %}
></civ-action-link>
