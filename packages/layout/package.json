{
  "name": "@civui/layout",
  "version": "0.1.0",
  "description": "CivUI layout components — Accordion, Card, Divider, InputGroup, PageHeader, Tag, List, ButtonGroup, ImagePreview, Image, Disclosure, ReadMore",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./accordion": "./dist/accordion/index.js",
    "./card": "./dist/card/index.js",
    "./disclosure": "./dist/disclosure/index.js",
    "./divider": "./dist/divider/index.js",
    "./input-group": "./dist/input-group/index.js",
    "./list": "./dist/list/index.js",
    "./page-header": "./dist/page-header/index.js",
    "./tag": "./dist/tag/index.js",
    "./button-group": "./dist/button-group/index.js",
    "./image-preview": "./dist/image-preview/index.js",
    "./image": "./dist/image/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@civui/actions": "workspace:*",
    "@civui/core": "workspace:*",
    "@civui/overlays": "workspace:*",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@civui/test-utils": "workspace:*",
    "@civui/tokens": "workspace:*",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
