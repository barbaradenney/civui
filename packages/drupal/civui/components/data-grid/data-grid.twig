<civ-data-grid
  {% if caption %}caption="{{ caption }}"{% endif %}
  {% if caption_hidden %}caption-hidden{% endif %}
  {% if sort_by %}sort-by="{{ sort_by }}"{% endif %}
  {% if sort_direction %}sort-direction="{{ sort_direction }}"{% endif %}
  {% if multi_sort %}multi-sort{% endif %}
  {% if responsive %}responsive="{{ responsive }}"{% endif %}
  {% if sticky_header %}sticky-header{% endif %}
  {% if selectable %}selectable="{{ selectable }}"{% endif %}
  {% if loading %}loading{% endif %}
  {% if error_message %}error-message="{{ error_message }}"{% endif %}
  {% if empty_message %}empty-message="{{ empty_message }}"{% endif %}
  {% if striped %}striped{% endif %}
  {% if bordered %}bordered{% endif %}
  {% if interactive %}interactive{% endif %}
  {% if group_by %}group-by="{{ group_by }}"{% endif %}
  {% if sticky_footer %}sticky-footer{% endif %}
  {% if show_group_subtotals %}show-group-subtotals{% endif %}
  {% if spacing %}spacing="{{ spacing }}"{% endif %}
></civ-data-grid>
