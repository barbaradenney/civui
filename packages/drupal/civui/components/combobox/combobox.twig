<civ-combobox
  {% if label %}label="{{ label }}"{% endif %}
  {% if hint %}hint="{{ hint }}"{% endif %}
  {% if error %}error="{{ error }}"{% endif %}
  {% if name %}name="{{ name }}"{% endif %}
  {% if value %}value="{{ value }}"{% endif %}
  {% if placeholder %}placeholder="{{ placeholder }}"{% endif %}
  {% if inputmode %}inputmode="{{ inputmode }}"{% endif %}
  {% if no_results_text %}no-results-text="{{ no_results_text }}"{% endif %}
  {% if required %}required{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if options %}options="{{ options }}"{% endif %}
  {% if width %}width="{{ width }}"{% endif %}
  {% if load_debounce %}load-debounce="{{ load_debounce }}"{% endif %}
  {% if min_query_length %}min-query-length="{{ min_query_length }}"{% endif %}
  {% if loading_text %}loading-text="{{ loading_text }}"{% endif %}
  {% if loading_error_text %}loading-error-text="{{ loading_error_text }}"{% endif %}
>
  {% block default %}{{ default }}{% endblock %}
</civ-combobox>
