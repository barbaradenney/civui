<civ-popover
  {% if open %}open{% endif %}
  {% if align %}align="{{ align }}"{% endif %}
  {% if panel_role %}panel-role="{{ panel_role }}"{% endif %}
  {% if trigger_haspopup %}trigger-haspopup="{{ trigger_haspopup }}"{% endif %}
  {% if no_tab_close %}no-tab-close{% endif %}
  {% if no_click_outside_close %}no-click-outside-close{% endif %}
  {% if no_escape_close %}no-escape-close{% endif %}
></civ-popover>
