<civ-yes-no
  {% if legend %}legend="{{ legend }}"{% endif %}
  {% if name %}name="{{ name }}"{% endif %}
  {% if value %}value="{{ value }}"{% endif %}
  {% if yes_label %}yes-label="{{ yes_label }}"{% endif %}
  {% if no_label %}no-label="{{ no_label }}"{% endif %}
  {% if required %}required{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if unsure_label %}unsure-label="{{ unsure_label }}"{% endif %}
  {% if unsure_value %}unsure-value="{{ unsure_value }}"{% endif %}
  {% if skip_label %}skip-label="{{ skip_label }}"{% endif %}
  {% if skip_value %}skip-value="{{ skip_value }}"{% endif %}
></civ-yes-no>
