<civ-select
  {% if label %}label="{{ label }}"{% endif %}
  {% if hint %}hint="{{ hint }}"{% endif %}
  {% if error %}error="{{ error }}"{% endif %}
  {% if name %}name="{{ name }}"{% endif %}
  {% if value %}value="{{ value }}"{% endif %}
  {% if preset %}preset="{{ preset }}"{% endif %}
  {% if preset_variant %}preset-variant="{{ preset_variant }}"{% endif %}
  {% if empty_label %}empty-label="{{ empty_label }}"{% endif %}
  {% if required %}required{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if options %}options='{{ options|json_encode|raw }}'{% endif %}
  {% if width %}width="{{ width }}"{% endif %}
  {% if autocomplete %}autocomplete="{{ autocomplete }}"{% endif %}
>
  {% block options %}{{ options }}{% endblock %}
</civ-select>
