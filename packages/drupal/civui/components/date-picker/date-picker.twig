<civ-date-picker
  {% if name %}name="{{ name }}"{% endif %}
  {% if value %}value="{{ value }}"{% endif %}
  {% if min %}min="{{ min }}"{% endif %}
  {% if max %}max="{{ max }}"{% endif %}
  {% if placeholder %}placeholder="{{ placeholder }}"{% endif %}
  {% if locale %}locale="{{ locale }}"{% endif %}
  {% if required %}required{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if week_starts_on %}week-starts-on="{{ week_starts_on }}"{% endif %}
  {% if choose_date_label %}choose-date-label="{{ choose_date_label }}"{% endif %}
  {% if selected_date_label %}selected-date-label="{{ selected_date_label }}"{% endif %}
  {% if dialog_label %}dialog-label="{{ dialog_label }}"{% endif %}
  {% if previous_month_label %}previous-month-label="{{ previous_month_label }}"{% endif %}
  {% if next_month_label %}next-month-label="{{ next_month_label }}"{% endif %}
  {% if dialog_opened_message %}dialog-opened-message="{{ dialog_opened_message }}"{% endif %}
  {% if date_selected_message %}date-selected-message="{{ date_selected_message }}"{% endif %}
  {% if today_label %}today-label="{{ today_label }}"{% endif %}
  {% if disabled_dates %}disabled-dates="{{ disabled_dates }}"{% endif %}
  {% if clear_label %}clear-label="{{ clear_label }}"{% endif %}
  {% if today_button_label %}today-button-label="{{ today_button_label }}"{% endif %}
  {% if hide_today_button %}hide-today-button{% endif %}
  {% if invalid_format_message %}invalid-format-message="{{ invalid_format_message }}"{% endif %}
  {% if date_range_message %}date-range-message="{{ date_range_message }}"{% endif %}
  {% if min_date_message %}min-date-message="{{ min_date_message }}"{% endif %}
  {% if max_date_message %}max-date-message="{{ max_date_message }}"{% endif %}
></civ-date-picker>
