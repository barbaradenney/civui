<civ-confirm-button
  {% if label %}label="{{ label }}"{% endif %}
  {% if success_label %}success-label="{{ success_label }}"{% endif %}
  {% if success_ms %}success-ms="{{ success_ms }}"{% endif %}
  {% if emphasis %}emphasis="{{ emphasis }}"{% endif %}
  {% if variant %}variant="{{ variant }}"{% endif %}
>
  {% block default %}{{ default }}{% endblock %}
</civ-confirm-button>
