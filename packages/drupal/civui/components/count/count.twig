<civ-count
  {% if label %}label="{{ label }}"{% endif %}
  {% if count %}count="{{ count }}"{% endif %}
  {% if max %}max="{{ max }}"{% endif %}
  {% if variant %}variant="{{ variant }}"{% endif %}
  {% if count_style %}count-style="{{ count_style }}"{% endif %}
  {% if spacing %}spacing="{{ spacing }}"{% endif %}
  {% if overlay %}overlay{% endif %}
  {% if live %}live="{{ live }}"{% endif %}
></civ-count>
