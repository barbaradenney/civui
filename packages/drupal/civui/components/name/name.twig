<civ-name
  {% if legend %}legend="{{ legend }}"{% endif %}
  {% if name %}name="{{ name }}"{% endif %}
  {% if hide_middle %}hide-middle{% endif %}
  {% if hide_suffix %}hide-suffix{% endif %}
  {% if required %}required{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if first_error %}first-error="{{ first_error }}"{% endif %}
  {% if middle_error %}middle-error="{{ middle_error }}"{% endif %}
  {% if last_error %}last-error="{{ last_error }}"{% endif %}
></civ-name>
