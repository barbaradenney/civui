{
  "name": "@civui/feedback",
  "version": "0.1.0",
  "description": "CivUI feedback components — Alert, Badge, Count, Spinner, Skeleton, Activity Timeline",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./alert": "./dist/alert/index.js",
    "./badge": "./dist/badge/index.js",
    "./count": "./dist/count/index.js",
    "./spinner": "./dist/spinner/index.js",
    "./skeleton": "./dist/skeleton/index.js",
    "./activity-timeline": "./dist/activity-timeline/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@civui/core": "workspace:*",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@civui/test-utils": "workspace:*",
    "@civui/tokens": "workspace:*",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
