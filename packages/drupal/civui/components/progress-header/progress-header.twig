<civ-progress-header
  {% if current is not null %}current="{{ current }}"{% endif %}
  {% if total is not null %}total="{{ total }}"{% endif %}
  {% if step_title %}step-title="{{ step_title }}"{% endif %}
  {% if size %}size="{{ size }}"{% endif %}
  {% if heading_level %}heading-level="{{ heading_level }}"{% endif %}
></civ-progress-header>
