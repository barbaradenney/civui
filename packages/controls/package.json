{
  "name": "@civui/controls",
  "version": "0.1.0",
  "description": "CivUI selection controls — Checkbox, radio, segmented control",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./checkbox": "./dist/checkbox/index.js",
    "./radio": "./dist/radio/index.js",
    "./segmented-control": "./dist/segmented-control/index.js"
  },
  "sideEffects": [
    "**/*.css",
    "src/*/civ-*.ts",
    "dist/*/civ-*.js"
  ],
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@civui/core": "workspace:*",
    "@civui/ui": "workspace:*",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@civui/test-utils": "workspace:*",
    "@civui/tokens": "workspace:*",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
