{
  "focus": {
    "$description": "W3C Two-Color Technique (C40) focus tokens. WCAG 2.2 SC 2.4.13 compliant.",
    "outline": {
      "color": { "$type": "color", "$value": "#face00", "$description": "High-visibility yellow focus outline" },
      "width": { "$type": "dimension", "$value": "3px", "$description": "Exceeds WCAG 2.2 minimum of 2px" },
      "offset": { "$type": "dimension", "$value": "2px", "$description": "Gap between element and outline" }
    },
    "shadow": {
      "color": { "$type": "color", "$value": "#0b0c0c", "$description": "Dark halo for contrast against light backgrounds" },
      "spread": { "$type": "dimension", "$value": "3px", "$description": "Halo width beyond outline" }
    }
  }
}
