    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@civui/core": "workspace:*",
    "@civui/feedback": "workspace:*",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@civui/storybook-utils": "workspace:*",
    "@civui/test-utils": "workspace:*",
    "@civui/tokens": "workspace:*",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
