{
  "name": "@civui/ui",
  "version": "0.1.0",
  "description": "CivUI general-purpose UI components — Button, Link, Badge, and more",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./button": "./dist/button/index.js",
    "./link": "./dist/link/index.js",
    "./tag": "./dist/tag/index.js",
    "./divider": "./dist/divider/index.js",
    "./card": "./dist/card/index.js",
    "./page-header": "./dist/page-header/index.js",
    "./link-card": "./dist/link-card/index.js",
    "./action-button": "./dist/action-button/index.js",
    "./button-group": "./dist/button-group/index.js",
    "./input-group": "./dist/input-group/index.js"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@civui/core": "workspace:*",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@civui/test-utils": "workspace:*",
    "@civui/tokens": "workspace:*",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
