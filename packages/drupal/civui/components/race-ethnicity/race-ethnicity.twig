<civ-race-ethnicity
  {% if legend %}legend="{{ legend }}"{% endif %}
  {% if name %}name="{{ name }}"{% endif %}
  {% if ethnicity_legend %}ethnicity-legend="{{ ethnicity_legend }}"{% endif %}
  {% if race_legend %}race-legend="{{ race_legend }}"{% endif %}
  {% if required %}required{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if ethnicity_error %}ethnicity-error="{{ ethnicity_error }}"{% endif %}
  {% if race_error %}race-error="{{ race_error }}"{% endif %}
  {% if layout %}layout="{{ layout }}"{% endif %}
></civ-race-ethnicity>
