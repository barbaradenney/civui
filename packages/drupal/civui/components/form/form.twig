<civ-form
  {% if action %}action="{{ action }}"{% endif %}
  {% if method %}method="{{ method }}"{% endif %}
  {% if persist %}persist="{{ persist }}"{% endif %}
  {% if error_heading_level and error_heading_level != 3 %}error-heading-level="{{ error_heading_level }}"{% endif %}
  {% if required_legend %}required-legend{% endif %}
  {% if confirm_before_submit %}confirm-before-submit{% endif %}
>
  {% block default %}{{ default }}{% endblock %}
</civ-form>
