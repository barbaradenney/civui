{
  "color": {
    "$description": "CivUI color palette — WCAG AA accessible combinations inspired by USWDS",
    "primary": {
      "$type": "color",
      "lightest": { "$value": "#d9e8f6" },
      "lighter": { "$value": "#73b3e7" },
      "light": { "$value": "#2378c3" },
      "DEFAULT": { "$value": "#005ea2" },
      "vivid": { "$value": "#0050d8" },
      "dark": { "$value": "#1a4480" },
      "darker": { "$value": "#162e51" }
    },
    "error": {
      "$type": "color",
      "lightest": { "$value": "#faf0f0", "$description": "Quietest pale pink-white surface — soft bg consumed by alert / badge / count / card / form-error-summary recipes" },
      "lighter": { "$value": "#f4caca", "$description": "Mid-pale pink-red — stronger soft bg between lightest and light, used by danger-button hover step (rest=lightest, hover=lighter, active=light). Tuned to clear AAA against `error.darkest` text" },
      "light": { "$value": "#d63e04" },
      "DEFAULT": { "$value": "#b50909" },
      "dark": { "$value": "#8b0a03" },
      "darkest": { "$value": "#5a0602", "$description": "Deeper red — AAA text + high-emphasis hero" }
    },
    "warning": {
      "$type": "color",
      "lightest": { "$value": "#faf3d1", "$description": "Quietest pale-cream surface (was `lighter` before the 2026-05-27 restructure)" },
      "lighter": { "$value": "#fcedb7", "$description": "Mid-pale yellow — stronger soft bg between lightest and light" },
      "light": { "$value": "#fee685" },
      "DEFAULT": { "$value": "#e5a000" },
      "dark": { "$value": "#936f38" },
      "darkest": { "$value": "#6b4c11", "$description": "Dark amber — AA text on warning-lightest" }
    },
    "success": {
      "$type": "color",
      "lightest": { "$value": "#ecf3ec", "$description": "Quietest pale-mint surface (was `lighter` before the 2026-05-27 restructure)" },
      "lighter": { "$value": "#b8e6b8", "$description": "Mid-pale green — stronger soft bg between lightest and light" },
      "light": { "$value": "#70e17b" },
      "DEFAULT": { "$value": "#00a91c" },
      "dark": { "$value": "#4d8055" },
      "darkest": { "$value": "#1a4d1a", "$description": "Dark green — AA text on success-lightest" }
    },
    "info": {
      "$type": "color",
      "lightest": { "$value": "#e7f6f8", "$description": "Quietest pale-cyan surface (was `lighter` before the 2026-05-27 restructure)" },
      "lighter": { "$value": "#c5ecf2", "$description": "Mid-pale cyan — stronger soft bg between lightest and light" },
      "light": { "$value": "#99deea" },
      "DEFAULT": { "$value": "#00bde3" },
      "dark": { "$value": "#2e6276" },
      "darkest": { "$value": "#1d4554", "$description": "Deeper teal — AAA text on info-lightest" }
    },
    "purple": {
      "$type": "color",
      "lightest": { "$value": "#ede3f3" },
      "lighter": { "$value": "#d0b8e0" },
      "light": { "$value": "#9b6bbf" },
      "DEFAULT": { "$value": "#7a3baf" },
      "dark": { "$value": "#54278f" }
    },
    "base": {
      "$type": "color",
      "lightest": { "$value": "#f0f0f0" },
      "lighter": { "$value": "#dfe1e2" },
      "light": { "$value": "#a9aeb1" },
      "DEFAULT": { "$value": "#71767a" },
      "dark": { "$value": "#565c65" },
      "darker": { "$value": "#3d4551" },
      "darkest": { "$value": "#1b1b1b" }
    },
    "white": {
      "$type": "color",
      "DEFAULT": { "$value": "#ffffff" }
    },
    "black": {
      "$type": "color",
      "DEFAULT": { "$value": "#000000" }
    },
    "accent": {
      "$type": "color",
      "cool": {
        "lightest": { "$value": "#e1f3f8" },
        "light": { "$value": "#97d4ea" },
        "DEFAULT": { "$value": "#00bde3" },
        "dark": { "$value": "#28a0cb" }
      },
      "warm": {
        "lightest": { "$value": "#f2e4d4" },
        "light": { "$value": "#ffbc78" },
        "DEFAULT": { "$value": "#fa9441" },
        "dark": { "$value": "#c05600" },
        "darkest": { "$value": "#7a3300", "$description": "Dark burnt orange — AA text on accent-warm-lightest" }
      }
    },
    "tag": {
      "$description": "Tag primary variant tokens — bg/text pairs for both light and dark mode",
      "blue": {
        "$type": "color",
        "bg": { "$value": "#1a4480" },
        "text": { "$value": "#ffffff" }
      },
      "teal": {
        "$type": "color",
        "bg": { "$value": "#2e6276" },
        "text": { "$value": "#ffffff" }
      },
      "red": {
        "$type": "color",
        "bg": { "$value": "#8b0a03" },
        "text": { "$value": "#ffffff" }
      },
      "green": {
        "$type": "color",
        "bg": { "$value": "#2e7d32" },
        "text": { "$value": "#ffffff" }
      },
      "yellow": {
        "$type": "color",
        "bg": { "$value": "#936f38" },
        "text": { "$value": "#ffffff" }
      },
      "orange": {
        "$type": "color",
        "bg": { "$value": "#c05600" },
        "text": { "$value": "#ffffff" }
      },
      "purple": {
        "$type": "color",
        "bg": { "$value": "#54278f" },
        "text": { "$value": "#ffffff" }
      },
      "gray": {
        "$type": "color",
        "bg": { "$value": "#565c65" },
        "text": { "$value": "#ffffff" }
      }
    }
  }
}
