<civ-address
  {% if legend %}legend="{{ legend }}"{% endif %}
  {% if name %}name="{{ name }}"{% endif %}
  {% if value %}value="{{ value }}"{% endif %}
  {% if hide_street2 %}hide-street2{% endif %}
  {% if show_country %}show-country{% endif %}
  {% if required %}required{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if variant %}variant="{{ variant }}"{% endif %}
  {% if show_street3 %}show-street3{% endif %}
  {% if street_error %}street-error="{{ street_error }}"{% endif %}
  {% if city_error %}city-error="{{ city_error }}"{% endif %}
  {% if state_error %}state-error="{{ state_error }}"{% endif %}
  {% if zip_error %}zip-error="{{ zip_error }}"{% endif %}
></civ-address>
