<civ-memorable-date
  {% if name %}name="{{ name }}"{% endif %}
  {% if value %}value="{{ value }}"{% endif %}
  {% if label %}label="{{ label }}"{% endif %}
  {% if locale %}locale="{{ locale }}"{% endif %}
  {% if required %}required{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if month_label %}month-label="{{ month_label }}"{% endif %}
  {% if day_label %}day-label="{{ day_label }}"{% endif %}
  {% if year_label %}year-label="{{ year_label }}"{% endif %}
  {% if month_empty_label %}month-empty-label="{{ month_empty_label }}"{% endif %}
  {% if day_placeholder %}day-placeholder="{{ day_placeholder }}"{% endif %}
  {% if year_placeholder %}year-placeholder="{{ year_placeholder }}"{% endif %}
  {% if date_set_message %}date-set-message="{{ date_set_message }}"{% endif %}
  {% if invalid_date_message %}invalid-date-message="{{ invalid_date_message }}"{% endif %}
></civ-memorable-date>
