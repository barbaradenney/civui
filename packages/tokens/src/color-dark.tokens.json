{
  "color": {
    "$description": "CivUI dark mode palette — WCAG AA accessible on dark backgrounds",
    "primary": {
      "$type": "color",
      "lightest": { "$value": "#1a3a5c" },
      "lighter": { "$value": "#2e6ca8" },
      "light": { "$value": "#5aa3e8" },
      "DEFAULT": { "$value": "#73b3e7" },
      "vivid": { "$value": "#5ea7f5" },
      "dark": { "$value": "#a4cef4" },
      "darker": { "$value": "#d0e4f8" }
    },
    "error": {
      "$type": "color",
      "lightest": { "$value": "#3a1a1a" },
