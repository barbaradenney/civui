{
  "name": "civui",
  "version": "0.1.0",
  "private": true,
  "description": "CivUI - Civic Design System: Accessibility-first web components for government applications",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "postbuild": "node scripts/minify.js",
    "minify": "node scripts/minify.js",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "playwright test tests/a11y.spec.ts",
    "test:visual": "playwright test tests/visual.spec.ts",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "lint:fix": "eslint 'packages/*/src/**/*.ts' --fix",
    "format": "prettier --write 'packages/*/src/**/*.{ts,json}'",
    "typecheck": "turbo typecheck",
    "prestorybook": "pnpm --filter @civui/tokens build && pnpm storybook:contract",
    "storybook": "storybook dev -p 6006",
    "prestorybook:build": "pnpm --filter @civui/tokens build && pnpm storybook:contract",
    "storybook:build": "storybook build",
    "parity": "node --experimental-strip-types tools/parity-report.ts && open tools/parity-report.html",
    "parity:schema": "tsx tools/schema-parity.ts",
    "validate:schemas": "tsx tools/validate-schemas.ts",
    "lint:fieldsets": "tsx tools/lint-fieldset-wrappers.ts",
    "lint:story-embeds": "tsx tools/lint-story-embeds.ts",
    "lint:story-names": "tsx tools/lint-story-names.ts",
    "lint:story-props": "tsx tools/lint-story-props.ts",
    "lint:prose-refs": "tsx tools/lint-prose-refs.ts",
    "lint:color-classes": "tsx tools/lint-color-classes.ts",
    "lint:jsdoc-props": "tsx tools/lint-jsdoc-props.ts",
    "lint:jsdoc-events": "tsx tools/lint-jsdoc-events.ts",
    "lint:safelist-stale": "tsx tools/lint-safelist-stale.ts",
    "lint:hardcoded-tokens": "tsx tools/lint-hardcoded-tokens.ts",
    "lint:coverage-trinity": "tsx tools/lint-coverage-trinity.ts",
    "lint:event-listener-leak": "tsx tools/lint-event-listener-leak.ts",
    "lint:host-display": "tsx tools/lint-host-display.ts",
    "lint:purged-variants": "tsx tools/lint-purged-variant-classes.ts",
    "lint:undefined-css-vars": "tsx tools/lint-undefined-css-vars.ts",
    "lint:dead-properties": "tsx tools/lint-dead-properties.ts",
    "lint:double-labels": "pnpm --filter @civui/compound exec vitest run src/_lint/double-labels.test.ts",
    "lint:missing-labels": "pnpm --filter @civui/compound exec vitest run src/_lint/missing-labels.test.ts",
    "lint:stacked-required": "pnpm --filter @civui/compound exec vitest run src/_lint/stacked-required.test.ts",
    "storybook:contract": "tsx tools/generate-contract-docs.ts",
    "scaffold:component": "tsx tools/scaffold-component.ts",
    "test:tools": "vitest run --config tools/vitest.config.ts",
    "sync:doc-tables": "tsx tools/sync-doc-tables.ts",
    "sync:drupal": "tsx tools/sync-drupal-sdc.ts && tsx tools/sync-drupal-twig.ts",
    "sync:drupal:sdc": "tsx tools/sync-drupal-sdc.ts",
    "sync:drupal:twig": "tsx tools/sync-drupal-twig.ts",
    "consistency": "node --experimental-strip-types tools/consistency-check.ts",
    "build:cdn": "node scripts/build-cdn.js",
    "validate:lints": "pnpm lint:fieldsets && pnpm lint:story-embeds && pnpm lint:story-names && pnpm lint:story-props && pnpm lint:prose-refs && pnpm lint:color-classes && pnpm lint:jsdoc-props && pnpm lint:jsdoc-events && pnpm lint:safelist-stale && pnpm lint:hardcoded-tokens && pnpm lint:coverage-trinity && pnpm lint:event-listener-leak && pnpm lint:host-display && pnpm lint:purged-variants && pnpm lint:undefined-css-vars && pnpm lint:dead-properties && pnpm lint:double-labels && pnpm lint:missing-labels && pnpm lint:stacked-required",
    "validate:doc-tables": "pnpm sync:doc-tables && git diff --exit-code -- 'apps/docs/docs/components/**/_*.props.mdx' 'apps/docs/docs/components/**/_*.events.mdx'",
    "validate:drift": "pnpm validate:lints && pnpm validate:doc-tables",
    "validate": "pnpm lint && pnpm typecheck && pnpm test && pnpm parity:schema --platforms && pnpm validate:schemas && pnpm validate:drift && pnpm test:tools"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "10.3.6",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/web-components-vite": "10.3.6",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "autoprefixer": "^10.4.0",
    "axe-core": "^4.11.4",
    "drupal-attribute": "^1.2.1",
    "drupal-twig-extensions": "1.0.0-beta.5",
    "esbuild": "^0.27.4",
    "eslint": "^9.0.0",
    "eslint-plugin-storybook": "10.3.6",
    "http-server": "^14.1.1",
    "jsdom": "^28.1.0",
    "locutus": "^3.0.14",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "storybook": "10.3.6",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "turbo": "^2.0.0",
    "twig": "^3.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-twig-drupal": "^1.6.2",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "hono": "^4.12.18",
      "@hono/node-server": "^1.19.10",
      "undici": "^7.21.0",
      "path-to-regexp": "^0.1.12",
      "brace-expansion": "^1.1.13",
      "serialize-javascript": "^7.0.3",
      "minimatch": "^3.1.2",
      "flatted": "^3.4.0",
      "fast-uri": "^3.1.1",
      "yaml": "^2.8.3",
      "picomatch": "^2.3.2",
      "lodash": "^4.18.0",
      "locutus": "^3.0.14",
      "rollup": "^4.59.0",
      "postcss": "^8.5.10",
      "ip-address": "^10.1.1",
      "esbuild": "^0.25.0",
      "@babel/plugin-transform-modules-systemjs": "^7.29.4",
      "express-rate-limit": "^8.2.2",
      "vite": "^6.4.2"
    }
  }
}
