<civ-pagination
  {% if total_items %}total-items="{{ total_items }}"{% endif %}
  {% if page_size %}page-size="{{ page_size }}"{% endif %}
  {% if page %}page="{{ page }}"{% endif %}
  {% if page_size_options %}page-size-options="{{ page_size_options }}"{% endif %}
  {% if sibling_count %}sibling-count="{{ sibling_count }}"{% endif %}
  {% if item_name %}item-name="{{ item_name }}"{% endif %}
  {% if item_name_plural %}item-name-plural="{{ item_name_plural }}"{% endif %}
></civ-pagination>
