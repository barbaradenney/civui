<civ-filter-chip
  {% if label %}label="{{ label }}"{% endif %}
  {% if value %}value="{{ value }}"{% endif %}
  {% if selected %}selected{% endif %}
  {% if removable %}removable{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if chip_style %}chip-style="{{ chip_style }}"{% endif %}
  {% if chip_role %}chip-role="{{ chip_role }}"{% endif %}
  {% if spacing %}spacing="{{ spacing }}"{% endif %}
  {% if icon_start %}icon-start="{{ icon_start }}"{% endif %}
  {% if icon_end %}icon-end="{{ icon_end }}"{% endif %}
  {% if count %}count="{{ count }}"{% endif %}
></civ-filter-chip>
